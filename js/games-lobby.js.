/**
 * js/games-lobby.js
 * Improved Real King Games Lobby — mobile-first, 20 cards, logos, lazy loader & launcher
 *
 * Drop into: js/games-lobby.js
 * Add to index.html after script.js:
 *    <script src="js/games-lobby.js" defer></script>
 *
 * Behavior:
 * - Renders 20 game cards into #games-grid (or creates it)
 * - Uses asset logos if present at /assets/games/{id}.png (or .webp/.jpg) else emoji fallback
 * - Play: lazy-loads js/games/{file} and instantiates with several fallbacks
 * - If game isn't implemented, shows polished demo modal
 */

(function () {
  const GAMES = [
    { id: 'classic-slots', title: 'Real King Slots', file: 'classic-slots.js', icon: '🎰', rtp: '96%', tags: ['Slot','Jackpot'], ctor: 'ClassicSlotsFullGame' },
    { id: 'aviator', title: 'Aviator', file: 'aviator.js', icon: '✈️', rtp: '94%', tags: ['Crash'], ctor: 'AviatorFullGame' },
    { id: 'roulette', title: 'Roulette', file: 'roulette.js', icon: '🎡', rtp: '97.3%', tags: ['Wheel'], ctor: 'RouletteFullGame' },
    { id: 'blackjack', title: 'Blackjack', file: 'blackjack.js', icon: '🃏', rtp: '99%', tags: ['Table'], ctor: 'BlackjackFullGame' },
    { id: 'baccarat', title: 'Baccarat', file: 'baccarat.js', icon: '🎲', rtp: '98%', tags: ['Table'], ctor: 'BaccaratFullGame' },
    { id: 'mines', title: 'Mines', file: 'mines.js', icon: '💣', rtp: '95%', tags: ['Arcade'], ctor: 'MinesFullGame' },
    { id: 'plinko', title: 'Plinko', file: 'plinko.js', icon: '🎯', rtp: '96%', tags: ['Arcade'], ctor: 'PlinkoFullGame' },
    { id: 'teen-patti', title: 'Teen Patti', file: 'teen-patti.js', icon: '♠️', rtp: '97%', tags: ['Card'], ctor: 'TeenPattiFullGame' },
    { id: 'andar-bahar', title: 'Andar Bahar', file: 'andar-bahar.js', icon: '🂡', rtp: '96%', tags: ['Card'], ctor: 'AndarBaharFullGame' },
    { id: 'sic-bo', title: 'Sic Bo', file: 'sic-bo.js', icon: '🎲', rtp: '95%', tags: ['Dice'], ctor: 'SicBoFullGame' },
    { id: 'video-poker', title: 'Video Poker', file: 'video-poker.js', icon: '🃏', rtp: '98%', tags: ['Poker'], ctor: 'VideoPokerFullGame' },
    { id: 'wheel-fortune', title: 'Wheel of Fortune', file: 'wheel-fortune.js', icon: '🛞', rtp: '96%', tags: ['Wheel'], ctor: 'WheelOfFortuneFullGame' },
    { id: 'keno-jackpot', title: 'Keno Jackpot', file: 'keno-jackpot.js', icon: '🎯', rtp: '94%', tags: ['Lottery'], ctor: 'KenoJackpotFullGame' },
    { id: 'jhandi-munda', title: 'Jhandi Munda', file: 'jhandi-munda.js', icon: '🎲', rtp: '95%', tags: ['Traditional'], ctor: 'JhandiMundaFullGame' },
    { id: 'dragon-tiger', title: 'Dragon Tiger', file: 'dragon-tiger.js', icon: '🐉', rtp: '97%', tags: ['Card'], ctor: 'DragonTigerFullGame' },
    { id: 'red-dog', title: 'Red Dog', file: 'red-dog.js', icon: '🂮', rtp: '96%', tags: ['Card'], ctor: 'RedDogFullGame' },
    { id: 'hi-low', title: 'Hi-Low', file: 'hi-low.js', icon: '🔢', rtp: '95%', tags: ['Card'], ctor: 'HiLowFullGame' },
    { id: 'ludo-betting', title: 'Ludo Betting', file: 'ludo-betting.js', icon: '🎲', rtp: '93%', tags: ['Multiplayer'], ctor: 'LudoBettingFullGame' },
    { id: 'car-roulette', title: 'Car Roulette', file: 'car-roulette.js', icon: '🏎️', rtp: '95%', tags: ['Race'], ctor: 'CarRouletteFullGame' },
    { id: 'classic-slots-2', title: 'Slots – Mega', file: 'classic-slots.js', icon: '🎰', rtp: '96%', tags: ['Slot'], ctor: 'ClassicSlotsFullGame' }
  ];

  const assetPaths = [
    id => `/assets/games/${id}.png`,
    id => `/assets/games/${id}.webp`,
    id => `/assets/games/${id}.jpg`,
    id => `/images/games/${id}.png`,
    id => `/images/games/${id}.webp`
  ];

  // DOM helper
  function create(tag, props = {}, children = []) {
    const el = document.createElement(tag);
    Object.entries(props).forEach(([k, v]) => {
      if (k === 'class') el.className = v;
      else if (k === 'html') el.innerHTML = v;
      else if (k.startsWith('data-')) el.setAttribute(k, v);
      else el[k] = v;
    });
    (Array.isArray(children) ? children : [children]).forEach(c => {
      if (!c) return;
      if (typeof c === 'string') el.appendChild(document.createTextNode(c));
      else el.appendChild(c);
    });
    return el;
  }

  // Lazy script loader cache
  const scriptCache = new Map();
  function loadScript(src) {
    if (scriptCache.has(src)) return scriptCache.get(src);
    const p = new Promise((res, rej) => {
      const s = document.createElement('script');
      s.src = src;
      s.async = true;
      s.onload = () => res(src);
      s.onerror = () => rej(new Error('Failed to load ' + src));
      document.head.appendChild(s);
    });
    scriptCache.set(src, p);
    return p;
  }

  // Try to get logo URL that exists (by trying to preload image)
  function findLogoFor(id) {
    return new Promise((resolve) => {
      let found = false;
      let tried = 0;
      assetPaths.forEach((fn, idx) => {
        const url = fn(id);
        const img = new Image();
        img.onload = () => { if (!found) { found = true; resolve(url); } };
        img.onerror = () => { tried++; if (tried === assetPaths.length && !found) resolve(null); };
        img.src = url;
      });
    });
  }

  // Create or get games-grid container
  function getGamesGrid() {
    let grid = document.getElementById('games-grid');
    if (!grid) {
      // try find first .grid.grid-cols-3 in home view
      grid = document.querySelector('#view-home .grid.grid-cols-3');
    }
    if (!grid) {
      const home = document.getElementById('view-home') || document.body;
      grid = create('div', { id: 'games-grid', class: 'grid grid-cols-3 gap-3' });
      // insert after featured card if present
      const featured = home.querySelector('.game-card');
      if (featured && featured.parentNode) featured.parentNode.insertBefore(grid, featured.nextSibling);
      else home.appendChild(grid);
    }
    return grid;
  }

  async function buildCard(game) {
    const card = create('div', { class: 'glass p-3 rounded-xl text-center', role: 'button', tabindex: 0, 'data-game-id': game.id, style: 'display:flex;flex-direction:column;align-items:center;justify-content:space-between;padding:10px;height:130px;' });

    const logoWrap = create('div', { style: 'width:68px;height:68px;border-radius:12px;overflow:hidden;display:flex;align-items:center;justify-content:center;background:linear-gradient(180deg,rgba(255,255,255,0.01),rgba(255,255,255,0.005));margin-bottom:8px;' });
    const title = create('div', { class: 'text-xs text-emerald-200/70', html: game.title, style: 'font-weight:700;margin-bottom:6px' });
    const meta = create('div', { class: 'text-[11px] text-emerald-200/50', html: `RTP ${game.rtp}` });

    // Try find logo; set placeholder first
    const placeholder = create('div', { class: 'text-3xl', html: game.icon });
    logoWrap.appendChild(placeholder);

    // async replace with real image if exists
    findLogoFor(game.id).then(url => {
      if (url) {
        logoWrap.innerHTML = '';
        const img = create('img', { src: url, alt: game.title + ' logo', style: 'width:100%;height:100%;object-fit:cover;display:block;' });
        logoWrap.appendChild(img);
      }
    });

    // Action row
    const actions = create('div', { style: 'display:flex;gap:6px;margin-top:8px' });
    const playBtn = create('button', { class: 'btn btn-mint text-xs', type: 'button', html: 'Play' });
    const infoBtn = create('button', { class: 'btn btn-glass text-xs', type: 'button', html: 'Info' });
    actions.appendChild(playBtn);
    actions.appendChild(infoBtn);

    card.appendChild(logoWrap);
    card.appendChild(title);
    card.appendChild(meta);
    card.appendChild(actions);

    // clicking card or playBtn launches
    const launchHandler = (e) => {
      e.stopPropagation();
      launchGame(game);
    };
    const infoHandler = (e) => {
      e.stopPropagation();
      showInfoModal(game);
    };

    card.addEventListener('click', launchHandler);
    card.addEventListener('touchstart', (e) => { e.stopPropagation(); launchHandler(e); }, { passive: true });
    card.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') launchHandler(e); });

    playBtn.addEventListener('click', launchHandler);
    infoBtn.addEventListener('click', infoHandler);

    return card;
  }

  // Build entire grid
  async function renderGrid() {
    const grid = getGamesGrid();
    grid.innerHTML = '';
    const fragment = document.createDocumentFragment();
    for (const g of GAMES) {
      const c = await buildCard(g);
      fragment.appendChild(c);
    }
    grid.appendChild(fragment);
  }

  // Modal creator (returns {overlay, canvas, close})
  function createModal(title, opts = {}) {
    const overlay = create('div', { class: 'fixed inset-0 z-60 flex items-center justify-center p-4' });
    overlay.style.background = 'linear-gradient(180deg, rgba(0,0,0,0.6), rgba(0,0,0,0.85))';
    const container = create('div', { class: 'glass rounded-2xl', style: 'width:100%;max-width:450px;padding:12px;display:flex;flex-direction:column;gap:8px;' });

    const header = create('div', { class: 'flex items-center justify-between' }, [
      create('div', { html: `<strong style="color:#fff">${title}</strong>` }),
      create('div', {}, [ create('button', { class: 'btn btn-glass', id: 'rk-close' }, 'Close') ])
    ]);

    const canvas = create('canvas', { style: 'width:100%;height:auto;border-radius:12px;background:#011713;' });
    // footer: spin + bet + balance
    const footer = create('div', { class: 'flex items-center justify-between' }, [
      create('div', { html: '<small class="text-emerald-200/60">Tap canvas or SPIN</small>' }),
      create('div', {}, [ create('button', { class: 'btn btn-mint', id: 'rk-spin' }, 'SPIN') ])
    ]);

    container.appendChild(header);
    container.appendChild(canvas);
    container.appendChild(footer);
    overlay.appendChild(container);
    document.body.appendChild(overlay);

    const closeBtn = overlay.querySelector('#rk-close');
    const spinBtn = overlay.querySelector('#rk-spin');

    const close = () => { try { overlay.remove(); } catch (e) {} };

    closeBtn.addEventListener('click', close);
    // also close on overlay click outside container
    overlay.addEventListener('click', (ev) => { if (ev.target === overlay) close(); });

    return { overlay, canvas, spinBtn, close };
  }

  // Instantiate game using multiple fallbacks
  async function instantiate(game, canvas) {
    const ctx = canvas.getContext('2d');
    // 1) createGameInstance(gameId, canvas, ctx)
    try {
      if (typeof window.createGameInstance === 'function') {
        const inst = window.createGameInstance(game.id, canvas, ctx);
        if (inst) return inst;
      }
    } catch (e) { console.warn('createGameInstance failed', e); }

    // 2) create{PascalName}()
    try {
      const pascal = game.ctor ? game.ctor.replace(/FullGame$/, '') : null;
      const createName = pascal ? 'create' + pascal : null;
      if (createName && typeof window[createName] === 'function') {
        return window[createName](canvas, ctx, { bet: 5 });
      }
    } catch (e) { console.warn('createX failed', e); }

    // 3) new window[Ctor]()
    try {
      if (game.ctor && typeof window[game.ctor] === 'function') {
        return new window[game.ctor](canvas, ctx);
      }
    } catch (e) { console.warn('ctor new failed', e); }

    // 4) try common name derived from id
    try {
      const pascalFromId = game.id.split(/[-_]/).map(s => s[0].toUpperCase()+s.slice(1)).join('') + 'FullGame';
      if (typeof window[pascalFromId] === 'function') return new window[pascalFromId](canvas, ctx);
    } catch (e) {}

    return null;
  }

  // Launch game: try instantiate immediately, else load script then try, else fallback demo
  async function launchGame(game) {
    try {
      // create modal
      const modal = createModal(game.title);
      const canvas = modal.canvas;
      // size canvas
      const parentWidth = Math.min(window.innerWidth - 28, 450);
      const dpr = window.devicePixelRatio || 1;
      canvas.style.width = parentWidth + 'px';
      canvas.width = Math.round(parentWidth * dpr);
      canvas.height = Math.round((parentWidth * 0.65) * dpr);
      canvas.getContext('2d').setTransform(dpr, 0, 0, dpr, 0, 0);

      // try instantiate (maybe module already loaded)
      let inst = await instantiate(game, canvas);
      if (inst) {
        startInstanceLoop(inst, modal);
        return;
      }

      // load script file
      const src = `js/games/${game.file}`;
      try {
        await loadScript(src);
      } catch (e) {
        console.warn('Script load failed', e);
      }

      // try instantiate again
      inst = await instantiate(game, canvas);
      if (inst) {
        startInstanceLoop(inst, modal);
        return;
      }

      // fallback polished demo
      fallbackDemo(game, canvas, modal);
    } catch (err) {
      console.error('launchGame error', err);
      alert('Unable to launch: ' + (err.message || err));
    }
  }

  // Start instance loop (if render exists)
  function startInstanceLoop(inst, modal) {
    const canvas = modal.canvas;
    const ctx = canvas.getContext('2d');
    // call lifecycle methods if available
    try { if (typeof inst.resize === 'function') inst.resize(); } catch (e) {}
    try { if (typeof inst.init === 'function') inst.init(); } catch (e) {}
    let raf = null;
    function loop(ts) {
      try {
        if (typeof inst.update === 'function') inst.update(ts);
        if (typeof inst.render === 'function') inst.render(ts);
      } catch (e) { console.warn('game loop error', e); }
      raf = requestAnimationFrame(loop);
    }
    raf = requestAnimationFrame(loop);
    // wire close to destroy
    const prevClose = modal.close;
    modal.close = function () {
      try { if (typeof inst.destroy === 'function') inst.destroy(); } catch (e) {}
      cancelAnimationFrame(raf);
      prevClose();
    };
    // spin button: try call instance.play
    modal.spinBtn.addEventListener('click', () => {
      try {
        if (typeof inst.play === 'function') inst.play(modal.bet || 1);
      } catch (e) { console.warn('play error', e); }
    });
  }

  // Polished fallback demo when module not present
  function fallbackDemo(game, canvas, modal) {
    const ctx = canvas.getContext('2d');
    const symbols = ['🍒','🍋','🍊','🔔','💎','⭐','7'];
    let t0 = performance.now();
    let raf;
    function draw(ts) {
      const t = (ts - t0) / 1000;
      ctx.clearRect(0,0,canvas.width,canvas.height);
      ctx.fillStyle = '#011713';
      ctx.fillRect(0,0,canvas.width,canvas.height);
      ctx.fillStyle = '#00e676';
      ctx.font = 'bold 16px system-ui';
      ctx.textAlign = 'left';
      ctx.fillText(game.title + ' — Demo', 12, 26);
      ctx.font = '48px serif';
      ctx.textAlign = 'center';
      for (let i=0;i<3;i++) {
        const x = canvas.width/4 + i*(canvas.width/4);
        const y = canvas.height/2 + Math.sin(t*2 + i)*28;
        ctx.fillStyle = '#fff';
        ctx.fillText(symbols[Math.floor((t*2 + i)) % symbols.length], x, y);
      }
      ctx.font = '12px system-ui';
      ctx.fillStyle = 'rgba(255,255,255,0.75)';
      ctx.textAlign = 'center';
      ctx.fillText('Module missing — playing polished demo', canvas.width/2, canvas.height - 24);
      raf = requestAnimationFrame(draw);
    }
    raf = requestAnimationFrame(draw);
    modal.spinBtn.addEventListener('click', () => {
      // small fake win toast
      const win = (Math.random()*30 + 1).toFixed(2);
      const toast = create('div', { style: 'position:fixed;left:50%;top:18px;transform:translateX(-50%);background:linear-gradient(90deg,rgba(255,215,0,0.12),rgba(0,230,118,0.06));color:#fff;padding:8px 12px;border-radius:999px;z-index:9999;font-weight:700;' }, `🎉 Demo WIN +${win} USD`);
      document.body.appendChild(toast);
      setTimeout(()=>{ toast.style.transition='all .4s'; toast.style.opacity='0'; toast.style.transform='translateX(-50%) translateY(-30px)'; }, 1000);
      setTimeout(()=> toast.remove(), 1600);
    });
    const prevClose = modal.close;
    modal.close = function () { cancelAnimationFrame(raf); prevClose(); };
  }

  // Show info modal (small)
  function showInfoModal(game) {
    const modal = createModal(game.title + ' — Info');
    const ctx = modal.canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.fillStyle = '#011713';
    ctx.fillRect(0,0,modal.canvas.width, modal.canvas.height);
    ctx.fillStyle = '#00e676';
    ctx.font = 'bold 16px system-ui';
    ctx.fillText(game.title, 16, 28);
    ctx.font = '12px system-ui';
    ctx.fillStyle = 'rgba(255,255,255,0.9)';
    const lines = [
      `Type: ${game.tags.join(', ')}`,
      `RTP: ${game.rtp}`,
      '',
      'Description: Premium Real King experience. Tap Play to launch the game.'
    ];
    let y = 56;
    lines.forEach(l => { ctx.fillText(l, 16, y); y += 18; });
    modal.spinBtn.style.display = 'none';
  }

  // createModal used above - reuse small helper from earlier to keep consistent
  function createModal(title) {
    const overlay = create('div', { class: 'fixed inset-0 z-60 flex items-center justify-center p-4' });
    overlay.style.background = 'linear-gradient(180deg, rgba(0,0,0,0.6), rgba(0,0,0,0.85))';
    const container = create('div', { class: 'glass rounded-2xl', style: 'width:100%;max-width:450px;padding:12px;display:flex;flex-direction:column;gap:8px;' });
    const header = create('div', { class: 'flex items-center justify-between' }, [
      create('div', { html: `<strong style="color:#fff">${title}</strong>` }),
      create('div', {}, [ create('button', { class: 'btn btn-glass', id: 'rk-close' }, 'Close') ])
    ]);
    const canvas = create('canvas', { style: 'width:100%;height:auto;border-radius:12px;background:#011713;' });
    const footer = create('div', { class: 'flex items-center justify-between' }, [
      create('div', { html: '<small class="text-emerald-200/60">Tap canvas or SPIN</small>' }),
      create('div', {}, [ create('button', { class: 'btn btn-mint', id: 'rk-spin' }, 'SPIN') ])
    ]);
    container.appendChild(header);
    container.appendChild(canvas);
    container.appendChild(footer);
    overlay.appendChild(container);
    document.body.appendChild(overlay);
    const closeBtn = overlay.querySelector('#rk-close');
    const spinBtn = overlay.querySelector('#rk-spin');
    const close = () => { try { overlay.remove(); } catch (e) {} };
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', (ev) => { if (ev.target === overlay) close(); });
    return { overlay, canvas, spinBtn, close };
  }

  // Initialize lobby on DOM ready
  function init() {
    renderGrid().catch(e => console.error('renderGrid error', e));
    // also ensure play-classic button from index header is wired
    const playClassic = document.getElementById('play-classic');
    if (playClassic) playClassic.addEventListener('click', () => launchGame(GAMES[0]));
    console.log('✅ Real King Games Lobby ready — total games:', GAMES.length);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();

})();
